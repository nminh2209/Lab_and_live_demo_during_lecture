# Embedding provider: mock | local | openai
EMBEDDING_PROVIDER=mock

# LLM provider for agent answers: mock | openai
LLM_PROVIDER=mock

# OpenAI credentials (required when LLM_PROVIDER=openai or EMBEDDING_PROVIDER=openai)
OPENAI_API_KEY=your-key-here
OPENAI_LLM_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Optional: set cache directories for the local all-MiniLM-L6-v2 embedder
# HF_HOME=./.hf-cache
# SENTENCE_TRANSFORMERS_HOME=./.sentence-transformers

# Optional: for ChromaDB persistence (bonus task)
# CHROMA_PERSIST_DIR=./chroma_data
