# Copy to prototype/server/.env (never commit .env)

# LLM Provider configuration: openai (default) | gemini
LLM_PROVIDER=openai

# OpenAI settings
OPENAI_API_KEY=sk-...
OPENAI_VISION_MODEL=gpt-4o-mini
OPENAI_PARSE_MODEL=gpt-4o-mini

# Gemini settings (if LLM_PROVIDER=gemini)
# You can use GEMINI_API_KEY, or it will fall back to using OPENAI_API_KEY value.
GEMINI_API_KEY=AIzaSy...
GEMINI_MODEL=gemini-1.5-flash
GEMINI_VISION_MODEL=gemini-1.5-flash

# Optional: VietOCR sidecar (python vietocr_service.py)
# OCR_MODE=auto | openai | vietocr
OCR_MODE=auto
VIETOCR_URL=http://127.0.0.1:5001

PORT=3000
