# =============================================================================
# Day 08 RAG Pipeline — Environment Variables
# Copy this file to .env and fill in your keys:
#   cp .env.example .env        (Linux/Mac)
#   copy .env.example .env      (Windows)
# =============================================================================

# --- OpenAI (Task 10 - Generation with citation) ---
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4o-mini
# DeepEval uses this model for metric scoring; set to gpt-4.1-nano for even cheaper runs.
DEEPEVAL_MODEL=gpt-4o-mini

# --- Jina AI (Task 7 - Reranking, optional) ---
# Get your key at: https://jina.ai/
JINA_API_KEY=jina_your-key-here

# --- PageIndex (Task 8 - Vectorless RAG, optional) ---
# Register at: https://pageindex.ai/
PAGEINDEX_API_KEY=pi_your-key-here

# --- Weaviate Cloud (Task 4, optional — project uses ChromaDB by default) ---
WEAVIATE_URL=https://xxx.weaviate.network
WEAVIATE_API_KEY=xxx
