# Required if using a real LLM provider
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional tracing — LangGraph + LLM runs export to LangSmith when set
# Get a key at https://smith.langchain.com/
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=multi-agent-research-lab

# Optional real web search via Tavily — falls back to LLM mock if unset
# Get a key at https://tavily.com/
TAVILY_API_KEY=

# Runtime config
APP_ENV=local
LOG_LEVEL=INFO
MAX_ITERATIONS=6
TIMEOUT_SECONDS=60
