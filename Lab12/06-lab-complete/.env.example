# Copy to .env.local for local Docker, or set on Render.
# Do NOT commit real secrets.

HOST=0.0.0.0
PORT=8000
ENVIRONMENT=development
DEBUG=true
LOG_LEVEL=INFO

APP_NAME=Production AI Agent
APP_VERSION=1.0.0

# Paste your OpenAI key here to use real LLM (optional — mock works offline)
OPENAI_API_KEY=
LLM_MODEL=gpt-4o-mini
USE_MOCK_LLM=false
LLM_FALLBACK_MOCK=true

AGENT_API_KEY=dev-key-change-me-in-production

RATE_LIMIT_PER_MINUTE=10
MONTHLY_BUDGET_USD=10.0

REDIS_URL=redis://localhost:6379/0
HISTORY_MAX_MESSAGES=20

ALLOWED_ORIGINS=http://localhost:3000,http://localhost
